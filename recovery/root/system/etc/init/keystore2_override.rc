# Override keystore2 configuration for OrangeFox Recovery
# This file prevents keystore2 auto-start during late-init to avoid crypto deadlock

service keystore2 /system/bin/keystore2 /tmp/misc/keystore
    class early_hal
    user root
    group root
    disabled
    seclabel u:r:recovery:s0

# Do not auto-start keystore2 during late-init
# on late-init
#     start keystore2
