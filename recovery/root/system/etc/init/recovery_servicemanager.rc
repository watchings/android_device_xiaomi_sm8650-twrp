# OrangeFox Recovery servicemanager deadlock fix
# This file provides init-level control of servicemanager lifecycle
# to prevent crypto-related deadlocks during boot

# Critical: Apply the servicemanager fix early in boot process
# This runs after filesystems are mounted but before decryption
on post-fs
    # Start servicemanager to allow any required service registrations
    start servicemanager
    # Wait for initialization (using exec with sleep)
    exec - root root -- /system/bin/sleep 2
    # Stop servicemanager to prevent deadlock
    stop servicemanager
    # Also stop related service managers
    stop hwservicemanager
    stop vndservicemanager
    stop keystore2

# Ensure all service managers stay disabled
on post-fs-data
    stop servicemanager
    stop hwservicemanager
    stop vndservicemanager
    stop keystore2

# Additional safety during boot phase
on boot
    stop servicemanager
    stop hwservicemanager
    stop vndservicemanager
    stop keystore2
