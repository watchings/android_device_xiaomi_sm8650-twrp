# Override hwservicemanager configuration for OrangeFox Recovery
# This file prevents hwservicemanager auto-start during init to avoid crypto deadlock

service hwservicemanager /system/bin/hwservicemanager
    user root
    group root readproc
    disabled
    seclabel u:r:recovery:s0
    writepid /dev/cpuset/system-background/tasks

# Do not auto-start hwservicemanager during init
# on init
#     start hwservicemanager
