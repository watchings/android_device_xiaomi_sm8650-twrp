+			std::string tempdir = "/persist/Fox";
+			SetValue("tw_settings_path", tempdir);
+			if (dcrpfail_count == 0) {
+				gui_print_color("warning", "I cannot load settings from encrypted device. I will use /persist for settings: %s\n", tempdir.c_str());
+				dcrpfail_count++; // don't spam the console with this warning
+			}
+		} else {
+			// Fallback to /data/recovery/Fox if /persist mount fails
+			std::string tempdir = TW_STORAGE_PATH"/Fox";
+			SetValue("tw_settings_path", tempdir);
+			if (dcrpfail_count == 0) {
+				gui_print_color("warning", "I cannot load settings from encrypted device and /persist is unavailable. I will try to save some settings to %s\n", tempdir.c_str());
