+			std::string tempdir = TW_STORAGE_PATH"/Fox";
+			SetValue("tw_settings_path", tempdir);
+			if (dcrpfail_count == 0) {
+				gui_print_color("warning", "I cannot load settings from encrypted device. I will try to save some settings to %s\n", tempdir.c_str());
