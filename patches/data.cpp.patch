+  #ifndef OF_DEVICE_WITHOUT_PERSIST
+  {
+    std::string persist_fox = "/persist/Fox";
+    if (PartitionManager.Mount_By_Path("/persist", false)) {
+      if (!TWFunc::Path_Exists(persist_fox))
+        TWFunc::Create_Dir_Recursive(persist_fox.c_str(), 0755, 0, 0);
