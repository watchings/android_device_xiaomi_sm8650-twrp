diff --git a/etc/init/keystore2.rc b/etc/init/keystore2.rc
index fa62662..b89f427 100644
--- a/etc/init/keystore2.rc
+++ b/etc/init/keystore2.rc
@@ -6,8 +6,11 @@
 #
 # See system/core/init/README.md for information on the init.rc language.
 
-on late-init
-    start keystore2
+# DO NOT auto-start keystore2 in recovery to prevent crypto deadlock
+# keystore2 repeatedly crashes during recovery boot and causes servicemanager deadlock
+# It can be started manually if needed, but for FDE/FBE decryption it's not required
+# on late-init
+#     start keystore2
 
 service keystore2 /system/bin/keystore2 /tmp/misc/keystore
     class early_hal
