diff --git a/etc/init/logd.rc b/etc/init/logd.rc
index 1234567..abcdefg 100644
--- a/etc/init/logd.rc
+++ b/etc/init/logd.rc
@@ -1,5 +1,7 @@
-on post-fs-data
-    start logd
+# Disabled auto-start of logd to prevent crash loop in recovery
+# logd crashes because /etc/task_profiles.json is missing
+# on post-fs-data
+#     start logd
 
 service logd /system/bin/logd
     class core late_start
@@ -10,6 +12,7 @@ service logd /system/bin/logd
     group root system readproc
     capabilities SYSLOG AUDIT_CONTROL
     priority 10
+    disabled
     writepid /dev/cpuset/system-background/tasks
