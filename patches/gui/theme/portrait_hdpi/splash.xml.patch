+<details>
+<resolution width="1080" h="1920"/>
+<themeversion>3</themeversion>
+</details>
+
+<resources>
+<image name="splash_logo" filename="SVG/Logos/logo_o.svg" retainaspect="1" scale="2.0"/>
+<image name="splash_bg" filename="Splash/user" retainaspect="1"/>
+<font name="of" filename="InterDisplay-Medium.ttf" size="64"/>
+<font name="recovery" filename="InterDisplay-Regular.ttf" size="52"/>
+<font name="console_font" filename="Roboto-Regular.ttf" size="16"/>
+<font name="button_font" filename="Roboto-Regular.ttf" size="24"/>
+</resources>
+
+<variables>
+<variable name="of" value="%screen_h%-400"/>
+<variable name="rec" value="%screen_h%-320"/>
+<variable name="screen_width" value="1080"/>
+<variable name="screen_height" value="1920"/>
+<variable name="header_color" value="#000000"/>
+<variable name="background_color" value="#000000"/>
+<variable name="button_color" value="#FF6600"/>
+<variable name="button_highlight_color" value="#FF8833"/>
+<variable name="button_text_color" value="#FFFFFF"/>
+<variable name="console_bg_color" value="#000000"/>
+<variable name="console_fg_color" value="#00FF00"/>
+<variable name="line_color" value="#FF6600"/>
+</variables>
+
+<pages>
+<page name="splash">
+<background color="%background_color%"/>
+
+<fill color="%header_color%">
+<placement x="0" y="0" w="%screen_width%" h="%screen_height%"/>
+</fill>
+
+<image>
+<image resource="splash_bg"/>
+<placement x="540" y="540" placement="4"/>
+</image>
+
+<image>
+<image resource="splash_logo"/>
+<placement x="540" y="540" placement="4"/>
+</image>
+
+<text style="menu_text">
+<placement x="540" y="%of%" placement="4"/>
+<font resource="of" color="#ffffff"/>
+<text>OrangeFox</text>
+</text>
+
+<text style="menu_text">
+<placement x="540" y="%rec%" placement="4"/>
+<font resource="recovery" color="#ffffff"/>
+<text>Recovery</text>
+</text>
+
+<!-- Horizontal divider line -->
+<fill color="%line_color%">
+<placement x="0" y="1200" w="%screen_width%" h="3"/>
+</fill>
+
+<!-- Button 1: Stop servicemanager -->
+<button>
+<placement x="80" y="1220" w="450" h="80"/>
+<fill color="%button_color%"/>
+<text>Stop SM</text>
+<font resource="button_font" color="%button_text_color%"/>
+<highlight color="%button_highlight_color%"/>
+<actions>
+<action function="cmd">setprop ctl.stop servicemanager</action>
+<action function="cmd">setprop ctl.stop hwservicemanager</action>
+<action function="cmd">setprop ctl.stop vndservicemanager</action>
+<action function="cmd">setprop ctl.stop keystore2</action>
+</actions>
+</button>
+
+<!-- Button 2: Start servicemanager -->
+<button>
+<placement x="550" y="1220" w="450" h="80"/>
+<fill color="%button_color%"/>
+<text>Start SM</text>
+<font resource="button_font" color="%button_text_color%"/>
+<highlight color="%button_highlight_color%"/>
+<actions>
+<action function="cmd">setprop ctl.start servicemanager</action>
+</actions>
+</button>
+
+<!-- Console for dmesg kernel & init log output - BLACK background with GREEN text -->
+<console>
+<placement x="40" y="1320" w="1000" h="560"/>
+<color foreground="%console_fg_color%" background="%console_bg_color%" scroll="#808080"/>
+<font resource="console_font" spacing="2" color="%console_fg_color%"/>
+</console>
+
+<!-- Action to display dmesg kernel & init logs on page load -->
+<action>
+<touch/>
+<actions>
+<action function="cmd">dmesg -w &</action>
+</actions>
+</action>
+</page>
+</pages>
 </recovery>
